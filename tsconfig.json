{
	"compilerOptions": {
		"target": "es2024",
		"module": "nodenext",
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": false, // todo
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*",
		"forge.config.ts"
	]
}
