{
	"compilerOptions": {
		"target": "es2024",
		"module": "preserve",
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": false, // todo
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*",
		"esbuilder.mts"
	]
}
